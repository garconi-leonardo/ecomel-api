# Configurações do Banco de Dados (Docker)
spring.datasource.url=jdbc:postgresql://ecomel-db:5432/ecomel
spring.datasource.username=user
spring.datasource.password=password
spring.datasource.driver-class-name=org.postgresql.Driver

# Configurações de JWT (Originais)
app.jwt.secret=MinhaChaveSuperSecretaComMaisDe64CaracteresParaGarantirASegurancaDoSistemaEcomel2024
app.jwt.expiration=86400000

user.ecomel=ECOMEL

# Hibernate / JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

logging.level.org.springframework.web=DEBUG
logging.level.org.springframework.security=DEBUG
server.error.include-message=always
